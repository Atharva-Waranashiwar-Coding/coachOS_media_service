{
  "version": 1,
  "disable_existing_loggers": false,
  "formatters": {
    "json": {
      "()": "app.core.logging.JsonFormatter"
    }
  },
  "handlers": {
    "stdout": {
      "class": "logging.StreamHandler",
      "formatter": "json",
      "stream": "ext://sys.stdout"
    }
  },
  "loggers": {
    "uvicorn": {
      "handlers": ["stdout"],
      "level": "INFO",
      "propagate": false
    },
    "uvicorn.error": {
      "handlers": ["stdout"],
      "level": "INFO",
      "propagate": false
    },
    "uvicorn.access": {
      "handlers": ["stdout"],
      "level": "WARNING",
      "propagate": false
    }
  }
}
