APP_NAME=CoachOS Media Service
APP_ENV=development
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://postgres:postgres@media-postgres:5432/coachos_media
JWT_SECRET_KEY=replace-with-shared-auth-secret
JWT_ALGORITHM=HS256
ATHLETE_SERVICE_URL=http://host.docker.internal:8002
ATHLETE_SERVICE_INTERNAL_URL=http://host.docker.internal:8002
INTERNAL_SERVICE_TOKEN=replace-with-internal-service-token
INTERNAL_SERVICE_NAME=media-service
OUTBOX_BATCH_SIZE=20
OUTBOX_POLL_INTERVAL_SECONDS=2
OUTBOX_MAX_ATTEMPTS=8
OUTBOX_BASE_RETRY_SECONDS=5
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio-secret
S3_BUCKET_NAME=coachos-videos
S3_ENDPOINT_URL=http://minio:9000
S3_PRESIGNED_URL_EXPIRATION_SECONDS=900
MAX_VIDEO_SIZE_BYTES=2147483648
ALLOWED_VIDEO_CONTENT_TYPES=video/mp4,video/quicktime,video/webm
DELETE_STORAGE_OBJECTS=true
TIMELINE_PUBLISHING_ENABLED=false
LOG_LEVEL=INFO
METRICS_ENABLED=true
REQUEST_ID_HEADER=X-Request-ID
RUN_MIGRATIONS=true
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
CORS_ORIGINS=http://localhost:5173
UPSTREAM_TIMEOUT_SECONDS=5
INSIGHT_MAX_BATCH_ATHLETES=100
INSIGHT_INTERNAL_SERVICE_TOKEN=replace-with-athlete-service-token
